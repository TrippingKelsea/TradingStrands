# AWS / Bedrock
AWS_REGION=us-west-2
AWS_PROFILE=default
BEDROCK_MODEL_ID=anthropic.claude-opus-4-6-v1:0

# Robinhood (v0 broker — unofficial API, MFA required)
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=
ROBINHOOD_MFA_SECRET=

# Alpaca (v1 broker)
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://api.alpaca.markets

# Orchestrator
TS_TICK_EQUITY_MS=5000
TS_TICK_CRYPTO_MS=1000
TS_LOG_LEVEL=INFO
